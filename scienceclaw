#!/bin/bash
# ScienceClaw — Your AI Research Colleague
# Wrapper: source .env, build runtime config, manage gateway lifecycle, delegate to openclaw.

# Do NOT use `set -e` globally — the watchdog and gateway lifecycle
# must survive transient failures without killing the process tree.

_resolve() {
  local src="${BASH_SOURCE[0]}"
  while [ -L "$src" ]; do
    local dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" && pwd
}

ROOT="$(_resolve)"
export SCIENCECLAW_ROOT="$ROOT"

[ -f "$ROOT/.env" ] && set -a && source "$ROOT/.env" && set +a

RUNTIME_DIR="$HOME/.scienceclaw"
RUNTIME_CONFIG="$RUNTIME_DIR/runtime-config.json"
GW_PORT=18789
GW_LOG="$RUNTIME_DIR/gateway.log"
GW_PID_FILE="$RUNTIME_DIR/gateway.pid"
GW_WATCHDOG_PID_FILE="$RUNTIME_DIR/watchdog.pid"
GW_WATCHDOG_INTERVAL="${SCIENCECLAW_WATCHDOG_INTERVAL:-30}"
GW_LOG_MAX_BYTES="${SCIENCECLAW_LOG_MAX_BYTES:-10485760}"  # 10 MB
CHANNEL_SCRIPT="$ROOT/scripts/channel.mjs"
WORKSPACE="$RUNTIME_DIR/workspace"
PROJECTS_DIR="$WORKSPACE/projects"
ACTIVE_PROJECT_FILE="$RUNTIME_DIR/active-project"

# Source i18n using a path that survives being sourced from temp dirs in tests
_I18N="${SCIENCECLAW_ROOT:-$ROOT}/scripts/i18n.sh"
[ -f "$_I18N" ] && source "$_I18N" || true

# ── Config builder ────────────────────────────────────────────────────

_remap_for_openrouter() {
  local json="$1"
  local remapped
  remapped=$(node -e '
    const c = JSON.parse(process.argv[1]);
    const providers = (c.models || {}).providers || {};

    const hasOR = Object.values(providers).some(
      p => (p.baseUrl || "").includes("openrouter.ai")
    );
    if (!hasOR) { process.stdout.write(process.argv[1]); process.exit(0); }

    const PROVIDER_PREFIX = {
      openai: "openai", claude: "anthropic", gemini: "google",
      deepseek: "deepseek", qwen: "qwen", meta: "meta-llama",
      mistral: "mistralai", cohere: "cohere", kimi: "moonshotai",
    };
    const ID_ALIAS = {
      "claude-sonnet-4-6": "claude-sonnet-4.6",
      "claude-opus-4-6":   "claude-opus-4.6",
      "deepseek-chat":     "deepseek-chat",
      "deepseek-reasoner": "deepseek-r1",
    };

    const refMap = {};

    for (const [key, prov] of Object.entries(providers)) {
      if (!(prov.baseUrl || "").includes("openrouter.ai")) continue;
      const prefix = PROVIDER_PREFIX[key] || key;
      for (const m of (prov.models || [])) {
        const oldId = m.id;
        if (oldId.includes("/")) continue;
        const canonical = ID_ALIAS[oldId] || oldId;
        const newId = prefix + "/" + canonical;
        refMap[key + "/" + oldId] = key + "/" + newId;
        m.id = newId;
      }
    }

    function remapRef(ref) {
      return ref && refMap[ref] || ref;
    }

    const agents = c.agents || {};
    const defaults = (agents.defaults || {}).model || {};
    if (defaults.primary) defaults.primary = remapRef(defaults.primary);
    if (Array.isArray(defaults.fallbacks)) {
      defaults.fallbacks = defaults.fallbacks.map(remapRef);
    }
    for (const agent of (agents.list || [])) {
      const am = agent.model || {};
      if (am.primary) am.primary = remapRef(am.primary);
      if (Array.isArray(am.fallbacks)) am.fallbacks = am.fallbacks.map(remapRef);
    }

    const media = (c.tools || {}).media || {};
    for (const section of Object.values(media)) {
      for (const m of (section.models || [])) {
        if ((m.baseUrl || "").includes("openrouter.ai") && m.model && !m.model.includes("/")) {
          const prefix = PROVIDER_PREFIX[m.provider] || m.provider;
          m.model = prefix + "/" + m.model;
        }
      }
    }

    process.stdout.write(JSON.stringify(c, null, 2));
  ' "$json" 2>/dev/null) || { printf '%s' "$json"; return 0; }

  if [ "$remapped" != "$json" ]; then
    echo "  🔄 OpenRouter detected — model IDs remapped" >&2
  fi
  printf '%s' "$remapped"
}

_build_runtime_config() {
  local tpl="$ROOT/openclaw.config.json"
  [ -f "$tpl" ] || { _msg config_missing >&2; return 1; }
  mkdir -p "$RUNTIME_DIR"

  local content
  content=$(<"$tpl")

  while [[ "$content" =~ \$\{([A-Za-z_][A-Za-z_0-9]*)(\:\-([^\}]*))?\} ]]; do
    local var_name="${BASH_REMATCH[1]}"
    local default_val="${BASH_REMATCH[3]}"
    local actual_val="${!var_name:-$default_val}"
    content="${content//${BASH_REMATCH[0]}/$actual_val}"
  done
  content="${content//\.\/skills/$ROOT/skills}"

  content="$(_remap_for_openrouter "$content")"
  content="$(_prune_unconfigured_providers "$content")"

  if [ -n "${TELEGRAM_PROXY:-}" ]; then
    local injected
    injected=$(node -e "
      const c = JSON.parse(process.argv[1]);
      if (c.channels && c.channels.telegram) c.channels.telegram.proxy = process.env.TELEGRAM_PROXY;
      process.stdout.write(JSON.stringify(c, null, 2));
    " "$content" 2>/dev/null)
    if [ -n "$injected" ]; then
      content="$injected"
    fi
  fi

  printf '%s' "$content" > "$RUNTIME_CONFIG"
}

_prune_unconfigured_providers() {
  local json="$1"
  node -e '
    const c = JSON.parse(process.argv[1]);
    const providers = (c.models || {}).providers || {};
    const removed = [];
    const PLACEHOLDER_RE = /your[-_]?(key|token|api|relay|openai|claude|gemini|deepseek)|^sk-your|^sk-ant-your|^sk-or-your|example|placeholder|change[-_]?me|xxx|test[-_]?key/i;
    for (const [key, prov] of Object.entries(providers)) {
      const k = prov.apiKey || "";
      if (!k || PLACEHOLDER_RE.test(k) || k.length < 10) {
        removed.push(key);
        delete providers[key];
      }
    }

    if (removed.length) {
      const remaining = Object.keys(providers);
      if (remaining.length === 0) {
        process.stderr.write("  ⚠️  No valid API keys found — run: ./scienceclaw setup\n");
        process.stdout.write(process.argv[1]);
        process.exit(0);
      }

      const agents = c.agents || {};
      const defaults = (agents.defaults || {}).model || {};
      const firstProvider = remaining[0];
      const firstModel = (providers[firstProvider].models || [])[0];

      function isAlive(ref) {
        if (!ref) return false;
        const prov = ref.split("/")[0];
        return remaining.includes(prov);
      }

      if (defaults.primary && !isAlive(defaults.primary)) {
        if (firstModel) {
          defaults.primary = firstProvider + "/" + firstModel.id;
          process.stderr.write("  🔄 Primary model auto-switched to " + defaults.primary + "\n");
        }
      }
      if (Array.isArray(defaults.fallbacks)) {
        defaults.fallbacks = defaults.fallbacks.filter(isAlive);
      }

      for (const agent of (agents.list || [])) {
        const am = agent.model || {};
        if (am.primary && !isAlive(am.primary)) {
          if (firstModel) am.primary = firstProvider + "/" + firstModel.id;
        }
        if (Array.isArray(am.fallbacks)) {
          am.fallbacks = am.fallbacks.filter(isAlive);
        }
      }
    }

    process.stdout.write(JSON.stringify(c, null, 2));
  ' "$json" 2>/dev/null || printf '%s' "$json"
}

# ── OpenClaw discovery ────────────────────────────────────────────────

_find_openclaw() {
  local candidate="$ROOT/node_modules/openclaw/openclaw.mjs"
  [ -f "$candidate" ] && { echo "$candidate"; return 0; }

  for f in "$ROOT"/node_modules/.pnpm/openclaw@*/node_modules/openclaw/openclaw.mjs; do
    [ -f "$f" ] && { echo "$f"; return 0; }
  done

  local resolved
  resolved="$(node -e "try{console.log(require.resolve('openclaw/openclaw.mjs'))}catch{}" 2>/dev/null)"
  [ -n "$resolved" ] && [ -f "$resolved" ] && { echo "$resolved"; return 0; }

  return 1
}

_require_engine() {
  if [ -z "${OPENCLAW:-}" ]; then
    OPENCLAW="$(_find_openclaw)" || {
      echo ""
      _msg engine_missing
      echo ""
      exit 1
    }
  fi
}

oc() { _require_engine; exec node "$OPENCLAW" "$@"; }

# ── Log rotation ──────────────────────────────────────────────────────

_rotate_log() {
  [ -f "$GW_LOG" ] || return 0
  local size
  size=$(wc -c < "$GW_LOG" 2>/dev/null | tr -d ' ') || return 0
  if [ "${size:-0}" -gt "$GW_LOG_MAX_BYTES" ]; then
    mv "$GW_LOG" "$GW_LOG.1" 2>/dev/null
    : > "$GW_LOG"
  fi
}

# ── Gateway process management ────────────────────────────────────────

_find_gateway_pid() {
  if command -v lsof >/dev/null 2>&1; then
    lsof -i :"$GW_PORT" -sTCP:LISTEN -t 2>/dev/null | head -1
  elif command -v ss >/dev/null 2>&1; then
    ss -tlnp 2>/dev/null | grep ":${GW_PORT} " | grep -oP 'pid=\K[0-9]+' | head -1
  elif command -v netstat >/dev/null 2>&1; then
    netstat -tlnp 2>/dev/null | grep ":${GW_PORT} " | awk '{print $NF}' | cut -d/ -f1 | head -1
  fi
}

is_gateway_running() {
  if command -v lsof >/dev/null 2>&1; then
    lsof -i :"$GW_PORT" -sTCP:LISTEN >/dev/null 2>&1
  elif command -v ss >/dev/null 2>&1; then
    ss -tlnp 2>/dev/null | grep -q ":${GW_PORT} "
  elif command -v netstat >/dev/null 2>&1; then
    netstat -tlnp 2>/dev/null | grep -q ":${GW_PORT} "
  else
    (echo >/dev/tcp/127.0.0.1/"$GW_PORT") 2>/dev/null
  fi
}

wait_for_gateway() {
  local i=0
  while [ $i -lt 30 ]; do
    is_gateway_running && return 0
    sleep 1
    i=$((i + 1))
  done
  return 1
}

_start_gateway_process() {
  _rotate_log
  export OPENCLAW_CONFIG_PATH="$RUNTIME_CONFIG"
  nohup node "$OPENCLAW" gateway run --force --port "$GW_PORT" \
    >> "$GW_LOG" 2>&1 &
  local pid=$!
  echo "$pid" > "$GW_PID_FILE"
  echo "$pid"
}

# ── Security checks ──────────────────────────────────────────────────

_check_security() {
  local token="${GATEWAY_AUTH_TOKEN:-change-me-before-production}"
  local has_external_channels=false

  if [ -f "$RUNTIME_CONFIG" ]; then
    local channels
    channels=$(node -e '
      const c = JSON.parse(require("fs").readFileSync(process.argv[1], "utf8"));
      const ch = c.channels || {};
      const active = Object.keys(ch).filter(k => ch[k].enabled !== false);
      console.log(active.join(","));
    ' "$RUNTIME_CONFIG" 2>/dev/null) || channels=""
    [ -n "$channels" ] && has_external_channels=true
  fi

  if [ "$token" = "change-me-before-production" ] || [ -z "$token" ]; then
    if $has_external_channels; then
      _msg sec_token_block
      _msg sec_token_block_h
      return 1
    else
      _msg sec_default_token
      _msg sec_token_hint
    fi
  fi

  if $has_external_channels; then
    if [ -f "$RUNTIME_CONFIG" ]; then
      local open_channels
      open_channels=$(node -e '
        const c = JSON.parse(require("fs").readFileSync(process.argv[1], "utf8"));
        const ch = c.channels || {};
        const open = Object.entries(ch)
          .filter(([,v]) => v.enabled !== false && JSON.stringify(v.allowFrom || []).includes("*"))
          .map(([k]) => k);
        if (open.length) console.log(open.join(", "));
      ' "$RUNTIME_CONFIG" 2>/dev/null) || open_channels=""
      if [ -n "$open_channels" ]; then
        _msg sec_open_access "$open_channels"
        _msg sec_open_hint
      fi
    fi
  fi

  return 0
}

# ── Watchdog ──────────────────────────────────────────────────────────

_run_watchdog() {
  trap '' HUP
  local backoff=2
  local max_backoff=120

  while true; do
    sleep "$GW_WATCHDOG_INTERVAL"
    _rotate_log

    if ! is_gateway_running 2>/dev/null; then
      echo "[$(date '+%Y-%m-%d %H:%M:%S')] watchdog: gateway down, restarting (backoff ${backoff}s)..." >> "$GW_LOG" 2>/dev/null
      sleep "$backoff"

      [ -f "$ROOT/.env" ] && set -a && source "$ROOT/.env" 2>/dev/null && set +a
      _build_runtime_config 2>/dev/null

      _start_gateway_process > /dev/null 2>&1

      if wait_for_gateway; then
        local new_pid
        new_pid=$(cat "$GW_PID_FILE" 2>/dev/null)
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] watchdog: recovered (PID ${new_pid:-?})" >> "$GW_LOG" 2>/dev/null
        backoff=2
      else
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] watchdog: restart failed, retry in ${backoff}s" >> "$GW_LOG" 2>/dev/null
        backoff=$((backoff * 2))
        [ "$backoff" -gt "$max_backoff" ] && backoff=$max_backoff
      fi
    else
      backoff=2
    fi
  done
}

_is_watchdog_alive() {
  [ -f "$GW_WATCHDOG_PID_FILE" ] || return 1
  local wpid
  wpid=$(cat "$GW_WATCHDOG_PID_FILE" 2>/dev/null) || return 1
  [ -n "$wpid" ] && kill -0 "$wpid" 2>/dev/null
}

_stop_watchdog() {
  if [ -f "$GW_WATCHDOG_PID_FILE" ]; then
    local wpid
    wpid=$(cat "$GW_WATCHDOG_PID_FILE" 2>/dev/null)
    if [ -n "$wpid" ] && kill -0 "$wpid" 2>/dev/null; then
      kill "$wpid" 2>/dev/null
      sleep 0.5
      kill -0 "$wpid" 2>/dev/null && kill -9 "$wpid" 2>/dev/null
    fi
    rm -f "$GW_WATCHDOG_PID_FILE"
  fi
}

_ensure_watchdog() {
  if _is_watchdog_alive; then
    return 0
  fi
  _stop_watchdog
  _run_watchdog &
  echo "$!" > "$GW_WATCHDOG_PID_FILE"
  disown
}

# ── High-level commands ───────────────────────────────────────────────

_validate_api_key() {
  [ -f "$RUNTIME_CONFIG" ] || return 0

  local result
  result=$(node -e '
    const fs = require("fs"), https = require("https"), http = require("http");
    const c = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const providers = (c.models || {}).providers || {};
    const keys = Object.entries(providers);
    if (keys.length === 0) { console.log("no_provider"); process.exit(0); }

    let tested = 0;
    let passed = 0;
    let remaining = keys.length;

    function done() {
      if (--remaining > 0) return;
      if (passed > 0) console.log("ok:" + passed + "/" + tested);
      else console.log("all_fail:" + tested);
    }

    for (const [name, prov] of keys) {
      if (!prov.apiKey || !prov.baseUrl) { done(); continue; }
      tested++;
      const url = new URL(prov.baseUrl.replace(/\/+$/, "") + "/models");
      const mod = url.protocol === "https:" ? https : http;
      const req = mod.request(url, {
        headers: { "Authorization": "Bearer " + prov.apiKey },
        timeout: 8000,
      }, (res) => {
        let d = "";
        res.on("data", c => d += c);
        res.on("end", () => {
          if (res.statusCode === 200 || res.statusCode === 301 || res.statusCode === 302) passed++;
          done();
        });
      });
      req.on("error", () => done());
      req.on("timeout", () => { req.destroy(); done(); });
      req.end();
    }
  ' "$RUNTIME_CONFIG" 2>/dev/null) || result="skip"

  case "$result" in
    ok:*) return 0 ;;
    skip) return 0 ;;
    no_provider)
      echo ""
      if [ "${SCIENCECLAW_LANG:-zh}" = "zh" ]; then
        echo "  ❌ 没有找到有效的 API Key"
        echo ""
        echo "  请先配置至少一个 LLM 服务商的 API Key："
        echo "    1. 运行 ./scienceclaw setup    （交互式配置）"
        echo "    2. 或者编辑 .env 文件手动填写"
        echo ""
        echo "  推荐: DeepSeek（国内直连，无需代理，很便宜）"
        echo "    注册: https://platform.deepseek.com/"
      else
        echo "  ❌ No valid API key found"
        echo ""
        echo "  Configure at least one LLM provider API key:"
        echo "    1. Run ./scienceclaw setup    (interactive)"
        echo "    2. Or edit .env manually"
        echo ""
        echo "  Recommended: DeepSeek (direct access from China, very affordable)"
        echo "    Sign up: https://platform.deepseek.com/"
      fi
      echo ""
      return 1
      ;;
    all_fail:*)
      echo ""
      if [ "${SCIENCECLAW_LANG:-zh}" = "zh" ]; then
        echo "  ❌ 所有已配置的 API Key 都无法连通"
        echo ""
        echo "  可能原因:"
        echo "    • API Key 已过期或无效"
        echo "    • 网络无法访问 API 服务（国内用户需要代理或使用 DeepSeek/yunwu.ai）"
        echo "    • Base URL 配置错误"
        echo ""
        echo "  诊断: ./scienceclaw doctor"
        echo "  重新配置: ./scienceclaw setup"
      else
        echo "  ❌ All configured API keys failed validation"
        echo ""
        echo "  Possible causes:"
        echo "    • API key expired or invalid"
        echo "    • Network cannot reach API endpoint (China users: try DeepSeek or yunwu.ai)"
        echo "    • Base URL misconfigured"
        echo ""
        echo "  Diagnose: ./scienceclaw doctor"
        echo "  Reconfigure: ./scienceclaw setup"
      fi
      echo ""
      return 1
      ;;
  esac
  return 0
}

ensure_gateway() {
  _require_engine
  if is_gateway_running; then
    _ensure_watchdog
    return 0
  fi
  _build_runtime_config || return 1
  _check_security || return 1
  _validate_api_key || return 1
  _msg gw_starting
  _start_gateway_process > /dev/null
  if wait_for_gateway; then
    local pid
    pid=$(cat "$GW_PID_FILE" 2>/dev/null)
    _msg gw_ready
    _ensure_watchdog
    _msg wd_active
    return 0
  else
    _msg gw_failed
    _msg gw_failed_log
    _msg gw_failed_tail
    tail -10 "$GW_LOG" 2>/dev/null | sed 's/^/     /'
    return 1
  fi
}

stop_gateway() {
  _stop_watchdog

  local stopped=false
  if [ -f "$GW_PID_FILE" ]; then
    local pid
    pid=$(cat "$GW_PID_FILE" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null
      sleep 1
      kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
      _msg gw_stopped
      stopped=true
    fi
    rm -f "$GW_PID_FILE"
  fi

  if ! $stopped && is_gateway_running; then
    local pid
    pid=$(_find_gateway_pid)
    if [ -n "$pid" ]; then
      kill "$pid" 2>/dev/null; sleep 1
      kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
      _msg gw_stopped
      stopped=true
    fi
  fi

  $stopped || _msg gw_not_running
}

_get_model_name() {
  if [ -f "$RUNTIME_CONFIG" ]; then
    node -e '
      const c = JSON.parse(require("fs").readFileSync(process.argv[1], "utf8"));
      const m = ((c.agents || {}).defaults || {}).model || {};
      const p = m.primary || "unknown";
      const parts = p.split("/");
      console.log(parts[parts.length - 1]);
    ' "$RUNTIME_CONFIG" 2>/dev/null || echo "unknown"
  else
    echo "unknown"
  fi
}

_get_active_channels() {
  if [ -f "$RUNTIME_CONFIG" ]; then
    node -e '
      const c = JSON.parse(require("fs").readFileSync(process.argv[1], "utf8"));
      const ch = c.channels || {};
      const active = Object.keys(ch).filter(k => ch[k].enabled !== false);
      console.log(active.length ? active.join(", ") : "");
    ' "$RUNTIME_CONFIG" 2>/dev/null || echo ""
  else
    echo ""
  fi
}

_get_active_project() {
  if [ -f "$ACTIVE_PROJECT_FILE" ]; then
    cat "$ACTIVE_PROJECT_FILE" 2>/dev/null
  else
    echo ""
  fi
}

show_status() {
  echo ""
  if is_gateway_running; then
    _msg status_running
    _msg status_model "$(_get_model_name)"
    local channels
    channels=$(_get_active_channels)
    if [ -n "$channels" ]; then
      _msg status_channels "$channels"
    fi
    local project
    project=$(_get_active_project)
    if [ -n "$project" ]; then
      _msg status_project "$project"
    fi
  else
    _msg status_stopped
  fi

  if _is_watchdog_alive; then
    _msg wd_active
  else
    _msg wd_not_running
  fi

  _msg status_log
  echo ""
}

