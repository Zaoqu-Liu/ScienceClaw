# ── Doctor command ────────────────────────────────────────────────────

run_doctor() {
  echo ""
  _msg doc_title
  echo ""

  _msg doc_section "--- System ---"

  # Node.js
  if command -v node >/dev/null 2>&1; then
    local nv
    nv=$(node -v)
    local major
    major=$(echo "$nv" | cut -d. -f1 | tr -d 'v')
    if [ "$major" -ge 22 ]; then
      _msg doc_ok "Node.js $nv"
    else
      _msg doc_warn "Node.js $nv (>= 22 recommended)"
    fi
  else
    _msg doc_fail "Node.js not found"
  fi

  # Python
  if command -v python3 >/dev/null 2>&1; then
    _msg doc_ok "Python $(python3 --version 2>&1 | cut -d' ' -f2)"
  else
    _msg doc_warn "Python 3 not found (needed for code execution)"
  fi

  # R
  if command -v Rscript >/dev/null 2>&1; then
    local rv
    rv=$(Rscript --version 2>&1 | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+') || rv="unknown"
    _msg doc_ok "R $rv"
  else
    _msg doc_warn "R not found (optional, for stats/visualization skills)"
  fi

  echo ""
  _msg doc_section "--- API ---"

  _check_provider_api() {
    local name="$1" base_url="$2" api_key="$3"
    if [ -z "$api_key" ] || [ "$api_key" = "sk-your-key" ] || [ "$api_key" = "your-key" ]; then
      return 1
    fi
    local http_code body
    body=$(curl -s -w "\n%{http_code}" --connect-timeout 5 \
      -H "Authorization: Bearer $api_key" \
      "${base_url}/models" 2>/dev/null) || { _msg doc_warn "$name: connection failed ($base_url)"; return 1; }
    http_code=$(echo "$body" | tail -1)
    if [ "$http_code" = "200" ]; then
      _msg doc_ok "$name: API reachable ($base_url)"
      return 0
    elif [ "$http_code" = "401" ] || [ "$http_code" = "403" ]; then
      _msg doc_fail "$name: invalid key or region-blocked (HTTP $http_code)"
      return 1
    elif [ "$http_code" = "000" ]; then
      _msg doc_warn "$name: connection timeout ($base_url)"
      return 1
    else
      _msg doc_warn "$name: HTTP $http_code ($base_url)"
      return 1
    fi
  }

  local _any_provider=false

  if [ -n "${OPENAI_API_KEY:-}" ] && [ "$OPENAI_API_KEY" != "sk-your-key" ]; then
    _check_provider_api "OpenAI" "${OPENAI_BASE_URL:-https://api.openai.com/v1}" "$OPENAI_API_KEY" && _any_provider=true
  fi
  if [ -n "${CLAUDE_API_KEY:-}" ] && [ "$CLAUDE_API_KEY" != "sk-your-key" ]; then
    _check_provider_api "Claude" "${CLAUDE_BASE_URL:-https://api.anthropic.com/v1}" "$CLAUDE_API_KEY" && _any_provider=true
  fi
  if [ -n "${GEMINI_API_KEY:-}" ] && [ "$GEMINI_API_KEY" != "your-key" ]; then
    _check_provider_api "Gemini" "${GEMINI_BASE_URL:-https://generativelanguage.googleapis.com/v1beta}" "$GEMINI_API_KEY" && _any_provider=true
  fi
  if [ -n "${DEEPSEEK_API_KEY:-}" ]; then
    _check_provider_api "DeepSeek" "${DEEPSEEK_BASE_URL:-https://api.deepseek.com/v1}" "$DEEPSEEK_API_KEY" && _any_provider=true
  fi

  if ! $_any_provider; then
    _msg doc_fail "No working API provider — run: ./scienceclaw setup"
  fi

  # Gateway token
  local token="${GATEWAY_AUTH_TOKEN:-}"
  if [ -z "$token" ] || [ "$token" = "change-me-before-production" ]; then
    _msg doc_warn "Using default gateway token — change for production"
  else
    _msg doc_ok "Gateway token configured"
  fi

  echo ""
  _msg doc_section "--- Gateway ---"

  if is_gateway_running; then
    _msg doc_ok "Gateway running (port $GW_PORT)"
  else
    _msg doc_warn "Gateway not running"
  fi

  if _is_watchdog_alive; then
    _msg doc_ok "Watchdog active"
  else
    _msg doc_warn "Watchdog not running"
  fi

  # Channels
  echo ""
  _msg doc_section "--- Channels ---"
  local channels
  channels=$(_get_active_channels)
  if [ -n "$channels" ]; then
    _msg doc_ok "Active: $channels"
  else
    _msg doc_warn "No channels configured"
  fi

  # Disk
  echo ""
  _msg doc_section "--- Workspace ---"
  if [ -d "$WORKSPACE" ]; then
    local ws_size
    ws_size=$(du -sh "$WORKSPACE" 2>/dev/null | cut -f1) || ws_size="?"
    _msg doc_ok "Workspace: $WORKSPACE ($ws_size)"
  else
    _msg doc_warn "Workspace not yet created"
  fi

  if [ -f "$GW_LOG" ]; then
    local log_size
    log_size=$(du -sh "$GW_LOG" 2>/dev/null | cut -f1) || log_size="?"
    _msg doc_ok "Log: $GW_LOG ($log_size)"
  fi

  echo ""
  _msg doc_section "--- Autostart ---"
  if _autostart_is_enabled; then
    _msg doc_ok "Autostart enabled"
  else
    _msg doc_warn "Autostart not configured — run: ./scienceclaw autostart enable"
  fi

  echo ""
}

# ── Skills command ────────────────────────────────────────────────────

run_skills() {
  local search_term="${1:-}"
  local catalog="$ROOT/skills/CATALOG.json"

  echo ""
  _msg skills_title
  echo ""

  if [ ! -f "$catalog" ]; then
    _msg doc_warn "CATALOG.json not found"
    return
  fi

  if [ -n "$search_term" ]; then
    node -e '
      const catalog = JSON.parse(require("fs").readFileSync(process.argv[1], "utf8"));
      const term = process.argv[2].toLowerCase();
      const matches = catalog.filter(s =>
        (s.name || "").toLowerCase().includes(term) ||
        (s.title || "").toLowerCase().includes(term) ||
        (s.description || "").toLowerCase().includes(term)
      );
      if (!matches.length) {
        console.log("  (none)");
        process.exit(0);
      }
      for (const s of matches) {
        console.log(`  ${s.name.padEnd(35)} ${(s.title || "").slice(0, 50)}`);
      }
    ' "$catalog" "$search_term"
  else
    node -e '
      const catalog = JSON.parse(require("fs").readFileSync(process.argv[1], "utf8"));
      console.log(`  共 ${catalog.length} 项\n`);

      const domains = {};
      const domainMap = {
        "literature": "📚 Literature / 文献",
        "search": "📚 Literature / 文献",
        "database": "🗄️  Databases / 数据库",
        "bioinformatics": "🧬 Bioinformatics / 生信",
        "genomics": "🧬 Bioinformatics / 生信",
        "proteomics": "🧬 Bioinformatics / 生信",
        "single-cell": "🧬 Bioinformatics / 生信",
        "transcriptomics": "🧬 Bioinformatics / 生信",
        "visualization": "📊 Visualization / 可视化",
        "plot": "📊 Visualization / 可视化",
        "chart": "📊 Visualization / 可视化",
        "clinical": "🏥 Clinical / 临床",
        "survival": "🏥 Clinical / 临床",
        "drug": "💊 Drug Discovery / 药物",
        "chemistry": "💊 Drug Discovery / 药物",
        "machine-learning": "🤖 Machine Learning / 机器学习",
        "statistics": "📐 Statistics / 统计",
      };

      for (const s of catalog) {
        let assigned = false;
        const text = [s.name, s.title, s.description].join(" ").toLowerCase();
        for (const [kw, domain] of Object.entries(domainMap)) {
          if (text.includes(kw)) {
            if (!domains[domain]) domains[domain] = [];
            domains[domain].push(s.name);
            assigned = true;
            break;
          }
        }
        if (!assigned) {
          const key = "🔬 Other / 其他";
          if (!domains[key]) domains[key] = [];
          domains[key].push(s.name);
        }
      }

      for (const [domain, skills] of Object.entries(domains).sort((a, b) => b[1].length - a[1].length)) {
        console.log(`  ${domain} (${skills.length})`);
        const preview = skills.slice(0, 5).join(", ");
        const more = skills.length > 5 ? `, ... +${skills.length - 5}` : "";
        console.log(`    ${preview}${more}`);
        console.log();
      }
    ' "$catalog"
  fi

  _msg skills_search
  echo ""
}

# ── Outputs command ───────────────────────────────────────────────────

run_outputs() {
  local subcmd="${1:-list}"
  echo ""
  _msg out_title
  echo ""

  case "$subcmd" in
    open)
      if [ -d "$PROJECTS_DIR" ]; then
        if command -v open >/dev/null 2>&1; then
          open "$PROJECTS_DIR"
        elif command -v xdg-open >/dev/null 2>&1; then
          xdg-open "$PROJECTS_DIR"
        else
          echo "  $PROJECTS_DIR"
        fi
      else
        _msg out_empty
      fi
      ;;
    clean)
      local days="${2:-30}"
      if [ -d "$WORKSPACE/quick" ]; then
        find "$WORKSPACE/quick" -type f -mtime +"$days" -delete 2>/dev/null
        find "$WORKSPACE/quick" -type d -empty -delete 2>/dev/null
      fi
      _msg out_cleaned "$days"
      ;;
    list|*)
      if [ -d "$PROJECTS_DIR" ] && [ "$(ls -A "$PROJECTS_DIR" 2>/dev/null)" ]; then
        for dir in "$PROJECTS_DIR"/*/; do
          [ -d "$dir" ] || continue
          local name
          name=$(basename "$dir")
          local file_count
          file_count=$(find "$dir" -type f 2>/dev/null | wc -l | tr -d ' ')
          local date_str=""
          local last_mod
          last_mod=$(stat -f "%m" "$dir" 2>/dev/null || stat -c "%Y" "$dir" 2>/dev/null || echo "")
          if [ -n "$last_mod" ]; then
            date_str=$(date -r "$last_mod" "+%Y-%m-%d" 2>/dev/null || date -d "@$last_mod" "+%Y-%m-%d" 2>/dev/null || echo "")
          fi
          echo "  📁 $name  ($file_count files${date_str:+, $date_str})"
        done
      else
        _msg out_empty
        _msg out_hint
      fi

      if [ -d "$WORKSPACE/quick" ] && [ "$(ls -A "$WORKSPACE/quick" 2>/dev/null)" ]; then
        echo ""
        echo "  📋 quick/"
        for dir in "$WORKSPACE/quick"/*/; do
          [ -d "$dir" ] || continue
          local name
          name=$(basename "$dir")
          local fc
          fc=$(find "$dir" -type f 2>/dev/null | wc -l | tr -d ' ')
          echo "     $name ($fc files)"
        done
      fi
      ;;
  esac
  echo ""
}

# ── Project command ───────────────────────────────────────────────────

run_project() {
  local subcmd="${1:-list}"
  shift 2>/dev/null || true

  case "$subcmd" in
    new)
      local title="$*"
      if [ -z "$title" ]; then
        if [ "${SCIENCECLAW_LANG:-zh}" = "zh" ]; then
          printf "  项目名称: "
        else
          printf "  Project name: "
        fi
        read title
      fi
      if [ -z "$title" ]; then
        echo "  ❌ Name required"
        return 1
      fi
      local slug
      slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | cut -c1-40)
      local date_str
      date_str=$(date +%Y-%m-%d)
      local dir_name="${slug}-${date_str}"
      local proj_dir="$PROJECTS_DIR/$dir_name"

      mkdir -p "$proj_dir/figures" "$proj_dir/reports" "$proj_dir/data"

      cat > "$proj_dir/README.md" << EOF
# $title

- Created: $date_str
- Status: Active

## Files

(auto-updated by ScienceClaw)
EOF

      echo "$title" > "$ACTIVE_PROJECT_FILE"

      # Write ACTIVE_PROJECT.md to workspace for agent
      mkdir -p "$WORKSPACE"
      cat > "$WORKSPACE/ACTIVE_PROJECT.md" << EOF
# Active Project

- **Title:** $title
- **Directory:** $proj_dir
- **Figures:** $proj_dir/figures/
- **Reports:** $proj_dir/reports/
- **Data:** $proj_dir/data/

Save all output files to the appropriate subdirectory above.
EOF

      echo ""
      if [ "${SCIENCECLAW_LANG:-zh}" = "zh" ]; then
        echo "  ✅ 项目已创建: $title"
        echo "     目录: $proj_dir"
        echo ""
        echo "  现在启动 ScienceClaw，它会自动将输出保存到该项目目录。"
      else
        echo "  ✅ Project created: $title"
        echo "     Directory: $proj_dir"
        echo ""
        echo "  Start ScienceClaw and outputs will be saved to this project."
      fi
      echo ""
      ;;

    list)
      echo ""
      if [ "${SCIENCECLAW_LANG:-zh}" = "zh" ]; then
        echo "  研究项目"
      else
        echo "  Research Projects"
      fi
      echo ""
      if [ -d "$PROJECTS_DIR" ] && [ "$(ls -A "$PROJECTS_DIR" 2>/dev/null)" ]; then
        local active
        active=$(_get_active_project)
        for dir in "$PROJECTS_DIR"/*/; do
          [ -d "$dir" ] || continue
          local name
          name=$(basename "$dir")
          local fc
          fc=$(find "$dir" -type f 2>/dev/null | wc -l | tr -d ' ')
          local marker=""
          if [ -n "$active" ] && head -1 "$dir/README.md" 2>/dev/null | grep -qF "$active"; then
            marker=" ← active"
          fi
          echo "  📁 $name  ($fc files)$marker"
        done
      else
        if [ "${SCIENCECLAW_LANG:-zh}" = "zh" ]; then
          echo "  暂无项目。创建: ./scienceclaw project new \"课题名称\""
        else
          echo "  No projects yet. Create one: ./scienceclaw project new \"topic\""
        fi
      fi
      echo ""
      ;;

    open)
      local target="$*"
      if [ -z "$target" ]; then
        echo "  Usage: ./scienceclaw project open <name>"
        return 1
      fi
      local found=""
      for dir in "$PROJECTS_DIR"/*/; do
        [ -d "$dir" ] || continue
        if [[ "$(basename "$dir")" == *"$target"* ]]; then
          found="$dir"
          break
        fi
      done
      if [ -n "$found" ]; then
        if command -v open >/dev/null 2>&1; then
          open "$found"
        elif command -v xdg-open >/dev/null 2>&1; then
          xdg-open "$found"
        else
          echo "  $found"
        fi
      else
        echo "  ❌ Project not found: $target"
      fi
      ;;

    archive)
      local target="$*"
      if [ -z "$target" ]; then
        echo "  Usage: ./scienceclaw project archive <name>"
        return 1
      fi
      local found=""
      for dir in "$PROJECTS_DIR"/*/; do
        [ -d "$dir" ] || continue
        if [[ "$(basename "$dir")" == *"$target"* ]]; then
          found="$dir"
          break
        fi
      done
      if [ -n "$found" ]; then
        mkdir -p "$RUNTIME_DIR/archives"
        local archive_name
        archive_name="$(basename "$found").zip"
        (cd "$PROJECTS_DIR" && zip -r "$RUNTIME_DIR/archives/$archive_name" "$(basename "$found")" >/dev/null 2>&1)
        if [ "${SCIENCECLAW_LANG:-zh}" = "zh" ]; then
          echo "  ✅ 已归档: $RUNTIME_DIR/archives/$archive_name"
        else
          echo "  ✅ Archived: $RUNTIME_DIR/archives/$archive_name"
        fi
      else
        echo "  ❌ Project not found: $target"
      fi
      ;;

    *)
      echo "  Usage: ./scienceclaw project <new|list|open|archive> [name]"
      ;;
  esac
}

# ── Autostart command ─────────────────────────────────────────────────

_autostart_plist_path="$HOME/Library/LaunchAgents/com.scienceclaw.gateway.plist"
_autostart_systemd_path="$HOME/.config/systemd/user/scienceclaw.service"

_find_node_path() {
  command -v node 2>/dev/null || echo "/usr/local/bin/node"
}

_autostart_is_enabled() {
  if [ "$(uname)" = "Darwin" ]; then
    [ -f "$_autostart_plist_path" ]
  elif [ -d /run/systemd/system ]; then
    systemctl --user is-enabled scienceclaw.service >/dev/null 2>&1
  else
    return 1
  fi
}

_autostart_enable() {
  _require_engine
  _build_runtime_config || return 1

  local node_path
  node_path=$(_find_node_path)

  if [ "$(uname)" = "Darwin" ]; then
    mkdir -p "$(dirname "$_autostart_plist_path")"
    cat > "$_autostart_plist_path" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.scienceclaw.gateway</string>
	<key>ProgramArguments</key>
	<array>
		<string>$node_path</string>
		<string>$OPENCLAW</string>
		<string>gateway</string>
		<string>run</string>
		<string>--force</string>
		<string>--port</string>
		<string>$GW_PORT</string>
	</array>
	<key>WorkingDirectory</key>
	<string>$ROOT</string>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>$RUNTIME_DIR/gateway-launchd.log</string>
	<key>StandardErrorPath</key>
	<string>$RUNTIME_DIR/gateway-launchd.log</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>$(dirname "$node_path"):/usr/local/bin:/usr/bin:/bin</string>
		<key>OPENCLAW_CONFIG_PATH</key>
		<string>$RUNTIME_CONFIG</string>
	</dict>
	<key>ThrottleInterval</key>
	<integer>10</integer>
	<key>ProcessType</key>
	<string>Background</string>
</dict>
</plist>
PLIST_EOF
    launchctl unload "$_autostart_plist_path" 2>/dev/null
    launchctl load "$_autostart_plist_path"
    _msg auto_installed
    _msg auto_detail_mac
    _msg auto_keepalive

  elif [ -d /run/systemd/system ]; then
    mkdir -p "$(dirname "$_autostart_systemd_path")"
    cat > "$_autostart_systemd_path" << SYSTEMD_EOF
[Unit]
Description=ScienceClaw Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=$ROOT
Environment=PATH=$(dirname "$node_path"):/usr/local/bin:/usr/bin:/bin
Environment=OPENCLAW_CONFIG_PATH=$RUNTIME_CONFIG
ExecStart=$node_path $OPENCLAW gateway run --force --port $GW_PORT
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
SYSTEMD_EOF
    systemctl --user daemon-reload
    systemctl --user enable --now scienceclaw.service
    _msg auto_installed
    _msg auto_detail_linux
    _msg auto_keepalive

  else
    _msg auto_unsupported
    return 1
  fi
}

_autostart_disable() {
  if [ "$(uname)" = "Darwin" ]; then
    if [ -f "$_autostart_plist_path" ]; then
      launchctl unload "$_autostart_plist_path" 2>/dev/null
      rm -f "$_autostart_plist_path"
      _msg auto_removed
    else
      _msg auto_not_found
    fi
  elif [ -d /run/systemd/system ]; then
    if systemctl --user is-enabled scienceclaw.service >/dev/null 2>&1; then
      systemctl --user disable --now scienceclaw.service
      rm -f "$_autostart_systemd_path"
      systemctl --user daemon-reload
      _msg auto_removed
    else
      _msg auto_not_found
    fi
  else
    _msg auto_unsupported
  fi
}

run_autostart() {
  local subcmd="${1:-status}"
  echo ""
  case "$subcmd" in
    enable|on)
      _autostart_enable
      ;;
    disable|off)
      _autostart_disable
      ;;
    status|*)
      if _autostart_is_enabled; then
        _msg auto_status_on
        _msg auto_hint_disable
      else
        _msg auto_status_off
        _msg auto_hint_enable
      fi
      ;;
  esac
  echo ""
}

# ── Models command ─────────────────────────────────────────────────────

run_models() {
  local subcmd="${1:-}"
  echo ""

  if [ ! -f "$RUNTIME_CONFIG" ]; then
    _build_runtime_config 2>/dev/null || true
  fi

  if [ ! -f "$RUNTIME_CONFIG" ]; then
    if [ "${SCIENCECLAW_LANG:-zh}" = "zh" ]; then
      _msg doc_fail "没有运行时配置，请先运行: ./scienceclaw setup"
    else
      _msg doc_fail "Runtime config not found. Run: ./scienceclaw setup"
    fi
    echo ""
    return 1
  fi

  node -e '
    const fs = require("fs");
    const https = require("https");
    const http = require("http");

    const lang = process.env.SCIENCECLAW_LANG || "zh";
    const T = {
      title:        lang === "zh" ? "  🔬 ScienceClaw 模型检测" : "  🔬 ScienceClaw Model Check",
      scanning:     lang === "zh" ? "  正在检测已配置的模型..." : "  Scanning configured models...",
      current:      lang === "zh" ? "  当前主模型" : "  Current primary model",
      testing:      lang === "zh" ? "  正在逐个测试..." : "  Testing each model...",
      results:      lang === "zh" ? "  检测结果" : "  Results",
      ok:           "✅",
      fail:         "❌",
      warn:         "⚠️ ",
      recommend:    lang === "zh" ? "  💡 建议" : "  💡 Recommendation",
      err_404:      lang === "zh" ? "模型已下架" : "model removed/deprecated",
      err_403:      lang === "zh" ? "地区不可用" : "region-blocked",
      err_429:      lang === "zh" ? "免费额度被挤爆，请稍后重试" : "rate limited, try later",
      err_402:      lang === "zh" ? "账户余额不足或额度用尽" : "account balance depleted",
      err_401:      lang === "zh" ? "API Key 无效" : "invalid API key",
      err_timeout:  lang === "zh" ? "连接超时" : "connection timeout",
      err_unknown:  lang === "zh" ? "未知错误" : "unknown error",
      tip_switch:   lang === "zh"
        ? "  当前模型不可用。请在 TUI 中用 /model 命令切换到上面 ✅ 的模型"
        : "  Current model unavailable. Use /model in TUI to switch to a ✅ model above",
      tip_allgood:  lang === "zh"
        ? "  当前模型工作正常！"
        : "  Current model is working!",
      tip_free:     lang === "zh"
        ? "  免费模型不稳定，建议使用 DeepSeek（很便宜）或 yunwu.ai 中转"
        : "  Free models are unstable. Consider DeepSeek (very cheap) or yunwu.ai relay",
      tip_nokey:    lang === "zh"
        ? "  没有找到有效的 API Key。请运行: ./scienceclaw setup"
        : "  No valid API key found. Run: ./scienceclaw setup",
    };

    function friendlyError(code, body) {
      if (code === 404) return T.err_404;
      if (code === 403) return T.err_403;
      if (code === 429) return T.err_429;
      if (code === 402) return T.err_402;
      if (code === 401) return T.err_401;
      if (code === 0)   return T.err_timeout;
      try {
        const msg = JSON.parse(body).error?.message || "";
        if (msg.includes("No endpoints")) return T.err_404;
        if (msg.includes("not available in your region")) return T.err_403;
        if (msg.includes("rate limit") || msg.includes("Rate limit")) return T.err_429;
        if (msg.includes("balance") || msg.includes("spend limit")) return T.err_402;
        if (msg.length > 0) return msg.slice(0, 60);
      } catch {}
      return T.err_unknown + " (HTTP " + code + ")";
    }

    function testModel(baseUrl, apiKey, modelId) {
      return new Promise((resolve) => {
        const payload = JSON.stringify({
          model: modelId,
          messages: [{ role: "user", content: "hi" }],
          max_tokens: 3,
        });
        const url = new URL(baseUrl.replace(/\/+$/, "") + "/chat/completions");
        const mod = url.protocol === "https:" ? https : http;
        const req = mod.request(url, {
          method: "POST",
          headers: {
            "Authorization": "Bearer " + apiKey,
            "Content-Type": "application/json",
            "Content-Length": Buffer.byteLength(payload),
          },
          timeout: 15000,
        }, (res) => {
          let data = "";
          res.on("data", (d) => data += d);
          res.on("end", () => resolve({ code: res.statusCode, body: data }));
        });
        req.on("error", () => resolve({ code: 0, body: "" }));
        req.on("timeout", () => { req.destroy(); resolve({ code: 0, body: "" }); });
        req.write(payload);
        req.end();
      });
    }

    async function main() {
      const config = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
      const providers = (config.models || {}).providers || {};
      const defaults = ((config.agents || {}).defaults || {}).model || {};
      const primary = defaults.primary || "";
      const fallbacks = defaults.fallbacks || [];

      console.log(T.title);
      console.log("");

      const allRefs = [primary, ...fallbacks].filter(Boolean);
      if (allRefs.length === 0) {
        console.log("  " + T.fail + " " + T.tip_nokey);
        console.log("");
        return;
      }

      console.log(T.current + ": " + primary);
      console.log(T.testing);
      console.log("");

      let primaryOk = false;
      let hasFreeModel = false;
      let firstGood = null;

      for (const ref of allRefs) {
        const parts = ref.split("/");
        const provKey = parts[0];
        const modelId = parts.slice(1).join("/");
        const prov = providers[provKey];
        if (!prov) {
          console.log("    " + T.fail + " " + ref + " — provider \"" + provKey + "\" not configured");
          continue;
        }

        const result = await testModel(prov.baseUrl, prov.apiKey, modelId);
        if (result.code === 200) {
          const marker = ref === primary ? " ← current" : "";
          console.log("    " + T.ok + " " + ref + marker);
          if (ref === primary) primaryOk = true;
          if (!firstGood) firstGood = ref;
        } else {
          const reason = friendlyError(result.code, result.body);
          const marker = ref === primary ? " ← current" : "";
          console.log("    " + T.fail + " " + ref + marker + " — " + reason);
        }

        if (modelId.includes(":free")) hasFreeModel = true;
      }

      console.log("");
      console.log(T.recommend);
      if (primaryOk) {
        console.log(T.tip_allgood);
      } else if (firstGood) {
        console.log(T.tip_switch);
        console.log("     " + T.ok + " " + firstGood);
      } else {
        console.log("  " + T.fail + " " + T.tip_nokey);
      }

      if (hasFreeModel) {
        console.log("");
        console.log("  " + T.warn + T.tip_free);
      }

      console.log("");
    }

    main().catch(e => { console.error("  Error:", e.message); process.exit(1); });
  ' "$RUNTIME_CONFIG"
}

# ── Preflight model check ──────────────────────────────────────────────

_preflight_model_check() {
  [ -f "$RUNTIME_CONFIG" ] || return 0

  local result
  result=$(node -e '
    const fs = require("fs");
    const https = require("https");
    const http = require("http");
    const config = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const providers = (config.models || {}).providers || {};
    const defaults = ((config.agents || {}).defaults || {}).model || {};
    const primary = defaults.primary || "";
    if (!primary) { console.log("skip"); process.exit(0); }

    const parts = primary.split("/");
    const provKey = parts[0];
    const modelId = parts.slice(1).join("/");
    const prov = providers[provKey];
    if (!prov || !prov.apiKey) { console.log("skip"); process.exit(0); }

    const payload = JSON.stringify({
      model: modelId,
      messages: [{ role: "user", content: "hi" }],
      max_tokens: 3,
    });
    const url = new URL(prov.baseUrl.replace(/\/+$/, "") + "/chat/completions");
    const mod = url.protocol === "https:" ? https : http;
    const req = mod.request(url, {
      method: "POST",
      headers: {
        "Authorization": "Bearer " + prov.apiKey,
        "Content-Type": "application/json",
        "Content-Length": Buffer.byteLength(payload),
      },
      timeout: 15000,
    }, (res) => {
      let data = "";
      res.on("data", d => data += d);
      res.on("end", () => {
        if (res.statusCode === 200) {
          console.log("ok");
        } else {
          let reason = "HTTP " + res.statusCode;
          try {
            const msg = JSON.parse(data).error?.message || "";
            if (res.statusCode === 404) reason = "model_removed";
            else if (res.statusCode === 403 && msg.includes("region")) reason = "region_blocked";
            else if (res.statusCode === 429) reason = "rate_limited";
            else if (res.statusCode === 402) reason = "no_balance";
            else if (res.statusCode === 401) reason = "bad_key";
            else reason = msg.slice(0, 80) || reason;
          } catch {}
          console.log("fail:" + res.statusCode + ":" + reason);
        }
      });
    });
    req.on("error", () => console.log("fail:0:timeout"));
    req.on("timeout", () => { req.destroy(); console.log("fail:0:timeout"); });
    req.write(payload);
    req.end();
  ' "$RUNTIME_CONFIG" 2>/dev/null) || result="skip"

  if [ "$result" = "ok" ] || [ "$result" = "skip" ]; then
    return 0
  fi

  local code reason model_name
  code=$(echo "$result" | cut -d: -f2)
  reason=$(echo "$result" | cut -d: -f3-)
  model_name=$(_get_model_name)

  echo ""
  if [ "${SCIENCECLAW_LANG:-zh}" = "zh" ]; then
    echo "  ⚠️  当前模型 ($model_name) 不可用"
    echo ""
    case "$reason" in
      model_removed)
        echo "  原因: 该模型已从服务商下架"
        echo "  解决: 进入 TUI 后输入 /model 切换到其他模型" ;;
      region_blocked)
        echo "  原因: 该模型在你所在地区不可用"
        echo "  解决: 换一个没有地区限制的模型（如 DeepSeek 或 Gemma）" ;;
      rate_limited)
        echo "  原因: 免费模型太多人用了，请求被限流"
        echo "  解决: 稍等几分钟重试，或切换到付费模型（更稳定）" ;;
      no_balance)
        echo "  原因: API 账户余额不足或消费限额已用完"
        echo "  解决: 去服务商后台充值，或切换到免费模型" ;;
      bad_key)
        echo "  原因: API Key 无效或已过期"
        echo "  解决: 检查 .env 中的 API Key 是否正确" ;;
      timeout)
        echo "  原因: 连接超时（网络问题或需要代理）"
        echo "  解决: 检查网络连接，国内用户建议用 DeepSeek 或 yunwu.ai 中转" ;;
      *)
        echo "  原因: $reason"
        echo "  解决: 运行 ./scienceclaw models 查看哪些模型可用" ;;
    esac
    echo ""
    echo "  💡 小贴士: 运行 ./scienceclaw models 可以检测所有模型的状态"
    echo "  💡 进入 TUI 后输入 /model 可以切换模型"
    echo ""
    echo "  仍然继续启动吗？(模型错误不影响其他功能，你可以进去后切换模型)"
  else
    echo "  ⚠️  Current model ($model_name) is unavailable"
    echo ""
    case "$reason" in
      model_removed)
        echo "  Cause: This model has been removed from the provider"
        echo "  Fix:   Use /model in TUI to switch to another model" ;;
      region_blocked)
        echo "  Cause: This model is not available in your region"
        echo "  Fix:   Switch to a model without region restrictions (e.g. DeepSeek, Gemma)" ;;
      rate_limited)
        echo "  Cause: Free model is overloaded (rate limited)"
        echo "  Fix:   Wait a few minutes or switch to a paid model (more reliable)" ;;
      no_balance)
        echo "  Cause: Account balance depleted or spend limit reached"
        echo "  Fix:   Top up your account or switch to a free model" ;;
      bad_key)
        echo "  Cause: API key is invalid or expired"
        echo "  Fix:   Check the API key in your .env file" ;;
      timeout)
        echo "  Cause: Connection timed out"
        echo "  Fix:   Check network. China users: try DeepSeek or yunwu.ai relay" ;;
      *)
        echo "  Cause: $reason"
        echo "  Fix:   Run ./scienceclaw models to check model availability" ;;
    esac
    echo ""
    echo "  💡 Tip: Run ./scienceclaw models to check all models"
    echo "  💡 Use /model in TUI to switch models"
    echo ""
    echo "  Continue anyway? (You can switch models inside the TUI)"
  fi
  echo ""
  return 0
}

# ── Command dispatch ──────────────────────────────────────────────────

case "${1:-}" in
  "")
    show_help
    ;;

  run)
    ensure_gateway || exit 1
    _preflight_model_check
    if [ ! -f "$WORKSPACE/.scienceclaw-initialized" ]; then
      mkdir -p "$WORKSPACE"
      echo ""
      _msg first_run_welcome
      _msg first_run_hint
      _msg first_run_ex1
      _msg first_run_ex2
      _msg first_run_ex3
      echo ""
      _msg first_run_more
      touch "$WORKSPACE/.scienceclaw-initialized"
    fi
    echo ""
    export OPENCLAW_CONFIG_PATH="$RUNTIME_CONFIG"
    oc tui
    ;;
  tui)
    ensure_gateway || exit 1
    _preflight_model_check
    echo ""
    shift
    export OPENCLAW_CONFIG_PATH="$RUNTIME_CONFIG"
    oc tui "$@"
    ;;
  start)
    _require_engine
    _build_runtime_config || exit 1
    _check_security || exit 1
    export OPENCLAW_CONFIG_PATH="$RUNTIME_CONFIG"
    shift
    exec node "$OPENCLAW" gateway run --force --port "$GW_PORT" "$@"
    ;;
  restart)
    stop_gateway
    sleep 1
    ensure_gateway || exit 1
    echo ""
    _msg gw_restarted
    ;;
  stop)
    stop_gateway
    ;;
  status)
    show_status
    ;;
  logs)
    tail -f "$GW_LOG" 2>/dev/null || _msg no_log
    ;;

  add)
    shift
    node "$CHANNEL_SCRIPT" add "$@"
    ;;
  remove)
    shift
    node "$CHANNEL_SCRIPT" remove "$@"
    ;;
  channels)
    if [ $# -le 1 ]; then
      node "$CHANNEL_SCRIPT" list
    else
      _require_engine
      _build_runtime_config || exit 1
      export OPENCLAW_CONFIG_PATH="$RUNTIME_CONFIG"
      oc "$@"
    fi
    ;;

  project|projects)
    shift
    run_project "$@"
    ;;

  models|model)
    _build_runtime_config 2>/dev/null || true
    run_models
    ;;

  doctor)
    run_doctor
    ;;

  skills)
    shift
    if [ "${1:-}" = "search" ]; then
      shift
      run_skills "$*"
    else
      run_skills "$*"
    fi
    ;;

  outputs)
    shift
    run_outputs "$@"
    ;;

  autostart)
    shift
    run_autostart "$@"
    ;;

  setup)
    bash "$ROOT/scripts/setup.sh"
    ;;
  help|--help|-h)
    show_help
    ;;

  recipes)
    echo ""
    _msg recipes_title
    echo "  ════════════════════════════════════════════"
    echo ""
    _msg recipes_desc
    echo ""
    _msg recipes_gene
    _msg recipes_target
    _msg recipes_lit
    _msg recipes_deg
    _msg recipes_clinical
    _msg recipes_person
    echo ""
    _msg recipes_usage
    _msg recipes_ex1
    _msg recipes_ex2
    echo ""
    ;;

  ask)
    shift
    clipboard=false
    if [ "${1:-}" = "--clipboard" ] || [ "${1:-}" = "-c" ]; then
      clipboard=true; shift
    fi
    _require_engine
    _build_runtime_config || exit 1
    ensure_gateway || exit 1
    export OPENCLAW_CONFIG_PATH="$RUNTIME_CONFIG"
    if $clipboard; then
      oc agent --agent scienceclaw --message "$*" | tee /dev/stderr | pbcopy 2>/dev/null || true
    else
      oc agent --agent scienceclaw --message "$*"
    fi
    ;;

  *)
    _require_engine
    _build_runtime_config || exit 1
    export OPENCLAW_CONFIG_PATH="$RUNTIME_CONFIG"
    oc "$@"
    ;;
esac
