# ScienceClaw — API Keys
# Copy to .env and fill in at least one LLM provider.

# Option A: Direct API access
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1

CLAUDE_API_KEY=sk-your-key
CLAUDE_BASE_URL=https://api.anthropic.com/v1

GEMINI_API_KEY=your-key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Option B: OpenAI-compatible relay (yunwu.ai, openrouter.ai, etc.)
# OPENAI_API_KEY=sk-your-relay-key
# OPENAI_BASE_URL=https://yunwu.ai/v1
# CLAUDE_API_KEY=sk-your-relay-key
# CLAUDE_BASE_URL=https://yunwu.ai/v1
# GEMINI_API_KEY=sk-your-relay-key
# GEMINI_BASE_URL=https://yunwu.ai/v1

# Optional: for diagram generation (Gemini image API)
# LLM_API_KEY=your-gemini-key

# Optional: for NCBI/PubMed searches
# NCBI_API_KEY=your-ncbi-key

# Optional: for Exa semantic search
# EXA_API_KEY=your-exa-key

# Optional: for Materials Project database
# MP_API_KEY=your-mp-key

# Sandbox configuration
# SCIENCECLAW_SANDBOX_IMAGE=scienceclaw-sandbox:latest
# SCIENCECLAW_WORKSPACE=~/.scienceclaw/workspace
# SCIENCECLAW_PYTHON=python3
