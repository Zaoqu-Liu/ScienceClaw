# ScienceClaw — Environment Variables
# Copy to .env and fill in at least one LLM provider.
# All values here are referenced by openclaw.config.json at runtime.

# ──── LLM Providers (at least one required) ────────────────────────
#
# Pick ONE option below. Uncomment the one that fits your situation.
# Priority: Option D (simplest for China) > Option B (relay) > Option C (OpenRouter) > Option A (direct)

# Option A: Direct API access (requires overseas network for OpenAI/Claude)
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1

CLAUDE_API_KEY=sk-your-key
CLAUDE_BASE_URL=https://api.anthropic.com/v1

GEMINI_API_KEY=your-key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Option B: OpenRouter (model IDs auto-remapped, no extra config needed)
#   ⚠️  Free-tier models (:free suffix) may be unstable or region-restricted.
#   ⚠️  Paid models are more reliable. Avoid :free models for production use.
# OPENAI_API_KEY=sk-or-your-openrouter-key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# CLAUDE_API_KEY=sk-or-your-openrouter-key
# CLAUDE_BASE_URL=https://openrouter.ai/api/v1
# GEMINI_API_KEY=sk-or-your-openrouter-key
# GEMINI_BASE_URL=https://openrouter.ai/api/v1

# Option D: DeepSeek (recommended for China — no proxy needed, very affordable)
#   Sign up: https://platform.deepseek.com/
#   DeepSeek V3 is the default model; R1 available for complex reasoning.
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ──── Gateway ──────────────────────────────────────────────────────

# Auth token for gateway connections (change this in production!)
GATEWAY_AUTH_TOKEN=change-me-before-production

# ──── Channels (optional) ─────────────────────────────────────────

# Telegram bot token (from @BotFather)
# TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram proxy (for regions where api.telegram.org is restricted)
# Supports SOCKS5 and HTTP proxies.
# TELEGRAM_PROXY=socks5://127.0.0.1:1080
# TELEGRAM_PROXY=http://127.0.0.1:7890

# ──── Web Search ──────────────────────────────────────────────────

# Brave Search API (free: 2000 queries/month, no credit card)
# Sign up: https://api-dashboard.search.brave.com/register
# BRAVE_API_KEY=BSA-your-key

# ──── Optional Service Keys ───────────────────────────────────────

# Gemini image generation
# LLM_API_KEY=your-gemini-key

# NCBI E-utilities (higher PubMed rate limits)
# NCBI_API_KEY=your-ncbi-key

# Exa semantic search
# EXA_API_KEY=your-exa-key

# Materials Project database
# MP_API_KEY=your-mp-key

# Asta Scientific Corpus (225M+ papers, full-text search)
# Free registration: https://allenai.org/asta/resources
# ASTA_API_KEY=your-asta-key

# ──── Sandbox ─────────────────────────────────────────────────────

# SCIENCECLAW_SANDBOX_IMAGE=scienceclaw-sandbox:latest
# SCIENCECLAW_WORKSPACE=~/.scienceclaw/workspace
# SCIENCECLAW_PYTHON=python3

# ──── Gateway Watchdog ───────────────────────────────────────────

# How often (seconds) the watchdog checks if the gateway is alive.
# SCIENCECLAW_WATCHDOG_INTERVAL=30
